{
  "name": "multi-tenant-erp",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:proxy": "docker run --rm --name erp-proxy -p 80:80 -v $(pwd)/Caddyfile:/etc/caddy/Caddyfile caddy:2-alpine",
    "dev:full": "pnpm dev:proxy & pnpm dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0"
}
